# Registry credentials for kpack builds.
# Copy to .env and fill in your values:
#   cp .env.example .env

# Docker Hub example:
#   REGISTRY_HOST=index.docker.io
#   REGISTRY_TAG_PREFIX=docker.io/myuser

# GitHub Container Registry example:
#   REGISTRY_HOST=ghcr.io
#   REGISTRY_TAG_PREFIX=ghcr.io/myorg

REGISTRY_HOST=index.docker.io
REGISTRY_USER=
REGISTRY_PASSWORD=
REGISTRY_TAG_PREFIX=docker.io/
