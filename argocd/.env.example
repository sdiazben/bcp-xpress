# ArgoCD reads from a GitHub repo for GitOps sync.
# Copy this file to argocd/.env and fill in your values.

# HTTPS clone URL of the repo containing argocd/manifests/
GITHUB_REPO_URL=https://github.com/<your-user>/bcp-xpress.git

# GitHub username
GITHUB_USER=<your-user>

# Personal Access Token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
